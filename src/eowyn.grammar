%
  prefix:      eowyn_
  lexer:       "whitespace: ignoreall=true"
  lexer:       keyword
  lexer:       identifier
  lexer:       "number: signed=false;float;hex;binary"
  lexer:       "qstring: quotes=\'\"`/"
  lexer:       "comment: marker=/* */;marker=//"
%

program                     :=                   [ program                   ] 
                               declarations      [ pop_program               ]
                             ;

declarations                := declaration
                               declarations
                             |
                             ;

declaration                 := variable_decl
                             | func_def
                             ;

statements                  := statement
                               ';'               [ add_statement             ]
                               statements
                             |
                             ;

statement                   := declaration
                             | conditional
                             | while_loop
                             | for_loop
                             | break
                             | continue
                             | switch
                             | return_stmt
                             | yield_stmt
                             | import_stmt
                             | new
                             | context_block
                             | throw
                             | leave
                             | assignment_or_call
                             | standalone_expr
                             ;

variable_decl               := var_decl
                             | const_decl
                             ;

var_decl                    := "var"
                               #ident
                               assignment_or_empty
                             ;

const_decl                  := "const"
                               #ident
                               assignment
                             ;

standalone_expr             := '(' expr ')'
                             ;

conditional                 := "if"
                               expr
                               statements
                               elif_seq
                               else
                               "end"
                             ;

elif_seq                    := elif
                               elif_seq
                             |
                             ;

elif                        := "elif"
                               expr
                               statements
                             ;

else                        := "else"
                               statements
                             |
                             ;

while_loop                  := "while"
                               expr
                               statements
                               "end"
                             ;

for_loop                    := "for"
                               identifier
                               "in"
                               expr
                               statements
                               "end"
                             ;

break                       := "break"
                             ;

continue                    := "continue"
                             ;

switch                      := "switch"
                               expr
                               cases
                               "end"
                             ;

cases                       := cases_seq
                               default
                             ;

cases_seq                   := case_block
                               cases_seq
                             |
                             ;

case_block                  := case_stmt
                               case_stmts
                               statements
                              ;

case_stmts                  := case_stmt
                               case_stmts
                             |
                             ;

case_stmt                   := "case"
                               expr
                               ':'
                             ;

default                     := "default"
                               ':'
                               statements
                             ;

func_def                    := func_type
                               #ident               [ push_identifier           ]             
                               (                 
                               parlist_or_void
                               )                 [ make_function_decl        ]
                               func_block        [ make_function             ]
                             ;

func_type                   := "func"            
                             | "threadfunc"
                             | "generator"
                             ;

func_block                  := {                 [ make_block                ]
                               statements
                               }
                             | link_clause
                             ;

link_clause                 := "->" '"'
                             ;

dummy                       :=
                             ;

parlist_or_void             := parlist
                             |
                             ;

parlist                     := param
                               parlist_tail
                             ;

param                       := #ident            [ make_parameter            ]
                             ;

parlist_tail                := ,
                               parlist
                             |
                             ;

lambda                      := "lambda"
                               ( 
                               parlist_or_void
                               )
                               statements
                               "end"
                             ;

return_stmt                 := "return"
                               expr
                             ;

yield_stmt                  := "yield"
                               expr
                             ;

new                         := "new"
                               identifier
                               func_call
                             ;

import_stmt                 := "import"
                               identifier
                             ;

context_block               := "context"
                               identifier
                               assignment_or_empty
                               statements
                               "end"
                             ;

assignment_or_empty         := assignment
                             |
                             ;

throw                       := "throw"
                               expr
                             ;

leave                       := "leave"
                             ;

assignment_or_call          := identifier
                               _assignment_or_call
                             ;

_assignment_or_call         := assignment
                             | func_calls
                             ;

func_calls                  := func_call
                               _func_calls
                             ;

_func_calls                 := .
                               var_or_calls
                             |
                             ;

assignment                  := =
                               expr
                             ;

expr                        := predicate
                               predicatetail
                             ;

reduction                   := '|'
                               expr
                               reduction_init
                             ;
 
reduction_init              := "<-"
                               expr
                             |     
                             ;

// FIXME the precedences of all logic- and bitwise operators are different.
predicatetail               := logic_op          [ push_current_token        ]
                               predicate         [ make_binary_expression    ]
                             | ternary
                             |
                             ;

ternary                     := ?
                               expr
                               :
                               expr
                             ;

predicate                   := term
                               termtail
                             ;

termtail                    := add_op            [ push_current_token        ]
                               term              [ make_binary_expression    ]
                               termtail
                             | reduction
                             |
                             ;

term                        := factor
                               factortail
                             ;

factortail                  := mult_op           [ push_current_token        ]     
                               factor            [ make_binary_expression    ]
                               factortail
                             |
                             ;

factor                      := expr_atom
                               subscript
                             ;

subscript                   := '[' expr ']'
                             |
                             ;

expr_atom                   := _expr_atom
                             ;  

_expr_atom                  := ( expr )
                             | var_or_calls
                             | new
                             | constant
                             | query
                             | lambda
                             ;

var_or_calls                := var_or_call
                               _var_or_calls
                             ;

_var_or_calls               := .
                               var_or_calls
                             |
                             ;

var_or_call                 := identifier     
                               call_or_empty
                             ;

call_or_empty               := func_call
                             |
                             ;

identifier                  := #ident               [ push_identifier           ]         
                               identifier_tail
                             ;

identifier_tail             := '.'
                               identifier
                             |
                             ;

query                       := '`'
                               query_params
                            ;

query_params                := '%' ( arglist )
                             |
                             ;

constant                    := '"'               [ make_qstring              ]
                             | '\''
                             | '/'
                             | signed_number
                             | list
                             | dict
                             | "true"            [ make_bool: "Bool:true"    ]
                             | "false"           [ make_bool: "Bool:false"   ]
                             | "null"
                             ;

signed_number               := sign              [ push_current_token        ]
                               number            [ make_unary_expression     ]
                             | number
                            ;

sign                        := +
                             | -
                             ;

number                      := int_number        [ make_int                  ]
                             | #float            [ make_float                ]
                             ;

int_number                  := #int
                             | #hex
                             | #binary
                             ;

list                        := '['
                               entrylist_or_empty
                               ']'
                             ;

entrylist_or_empty          := entry
                               comprehension_or_tail
                             |
                             ;

entry                       := expr
                             ;

comprehension_or_tail       := comprehension
                             | entrylist_tail
                             ;

entrylist                   := entry
                               entrylist_tail
                             ;

entrylist_tail              := ,
                               entrylist
                             |
                             ;

comprehension               := "for"
                               identifier
                               "in"
                               expr
                               where_or_empty
                             ;

where_or_empty              := where
                             |
                             ;

where                       := "where"
                               expr
                             ;

dict                        := '{'
                               attrlist_or_empty
                               '}'
                             ;

attrlist_or_empty           := attrlist
                             |
                             ;

attrlist                    := attrname
                               ':'
                               expr
                               attrlist_tail
                             ;

attrname                    := #ident | '"' | '\'' ;

attrlist_tail               := ,
                               attrlist
                             |
                             ;

logic_op                    := > | ">=" | < | "<=" | "==" | "!=" | "||" | "&&" | "and" | "or"
                             ;

add_op                      := + | - | ~
                             ;

mult_op                     := * | / | ^ | %
                             ;

func_call                  := (
                               arglist_or_void
                              )                  [ make_function_call        ]
                             ;

arglist_or_void             := arglist
                             |
                             ;

arglist                     := argument
                               arglist_tail
                             ;

argument                    := expr
                             ;

arglist_tail                := ,
                               arglist
                             |
                             ;
